{
  "name": "@Penta-web-app/api",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./routers": {
      "types": "./dist/routers/index.d.ts",
      "default": "./src/routers/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "@Penta-web-app/config": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@orpc/server": "catalog:",
    "@orpc/client": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/zod": "catalog:",
    "hono": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@Penta-web-app/auth": "workspace:*",
    "@Penta-web-app/db": "workspace:*"
  }
}
